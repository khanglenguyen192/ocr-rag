# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="OCR Web Platform"
APP_VERSION="1.0.0"
DEBUG=true

# ── Model (LightOnOCR-2-1B) ───────────────────────────────────────────────────
# Local path (model đã tải về):
MODEL_DIR=../LightOnOCR-2-1B
# Hoặc HuggingFace ID (tải online):
# MODEL_DIR=lightonai/LightOnOCR-2-1B

# ── OCR Parameters ────────────────────────────────────────────────────────────
PDF_DPI=150          # Render resolution (MPS: 150 | CUDA: 200)
IMG_MAX=1024         # Max image dimension in px before OCR
MAX_TOKENS=1024      # Max output tokens per image

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["*"]
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://localhost:5175","http://localhost:5176"]


